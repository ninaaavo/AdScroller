{
    "name": "Ad Scroller",
    "description": "Scroller to ads",
    "version": "1.0",
    "manifest_version": 3,
    "action": {
        
    },
    "permissions": ["activeTab", "scripting", "storage","tabs"],
    "background": {
        "service_worker":"background.js"
    },
    "host_permissions": 
        [
            "http://*/*",
            "https://*/*"
        ]
}